# ================================
# 前端应用环境变量配置示例
# ================================
# 使用说明：
# 1. 本地开发: 复制此文件为 .env.local 并填写实际的值
# 2. Docker 部署: 在 docker-compose.yml 中配置或创建 .env 文件
# 3. NEXT_PUBLIC_ 前缀的变量会暴露给浏览器端，请勿存储敏感信息

# ================================
# 应用端口配置
# ================================
WEB_PORT=3000

# ================================
# 后端 API 配置
# ================================
# 浏览器端访问的后端 API 地址
# 开发环境: http://localhost:8000
# 生产环境: 使用实际的公网域名或 IP，例如：https://api.yourdomain.com
NEXT_PUBLIC_API_URL=http://localhost:8000

# 向后兼容：NEXT_PUBLIC_API_BASE_URL 和 NEXT_PUBLIC_API_URL 是同一个配置
# 如果两者都配置，将使用 NEXT_PUBLIC_API_URL
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# 服务器端渲染时访问的后端 API 地址（内部容器通信）
# Docker 部署时使用容器名称: http://app_backend:8000
# 本地开发时使用: http://localhost:8000
INTERNAL_API_URL=http://app_backend:8000

# ================================
# Node 环境
# ================================
# development | production | test
NODE_ENV=production
